[Unit]
Description=Meal Suggester API
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/meal-suggester
EnvironmentFile=/home/ec2-user/meal-suggester/.env
ExecStart=/home/ec2-user/meal-suggester/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
